---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'VibeFlow',
    description: 'Open-source macOS voice-to-text app. Fully offline speech recognition with AI text cleanup via on-device Whisper and Qwen models.',
    tech: ['Swift', 'SwiftUI', 'WhisperKit', 'MLX', 'CoreAudio'],
    href: 'https://vibeflow.agarwalvivek.com',
    // projectPage: '/projects/vibeflow',
  },
  {
    title: 'SkillBridge',
    description: 'AI-powered freelance platform with Solana smart contract escrow. Claude AI verifies deliverable quality, on-chain escrow guarantees payment.',
    tech: ['Next.js', 'FastAPI', 'Solana', 'TypeScript', 'PostgreSQL'],
    href: 'https://skillbridge.agarwalvivek.com',
    // projectPage: '/projects/skillbridge',
  },
  {
    title: 'EcoTokens',
    description: 'Web3 carbon credit marketplace on Ethereum. NFT-based carbon offsets, smart contract automation, ML-based credit prediction.',
    tech: ['React', 'Node.js', 'Solidity', 'Web3.js', 'MongoDB'],
    href: 'https://github.com/agarwalvivek29/sheCodes',
    // projectPage: '/projects/ecotokens',
  },
  {
    title: 'Memory Insight',
    description: 'Forensic memory analysis platform. Async memory capture and analysis via microservices.',
    tech: ['Next.js', 'FastAPI', 'PostgreSQL', 'RabbitMQ', 'AWS'],
    href: 'https://github.com/agarwalvivek29/memory-insight',
    // projectPage: '/projects/memory-insight',
  },
  {
    title: 'SIH 2024 SCADA',
    description: 'SCADA system for Gas Authority of India Ltd. Smart India Hackathon 2024 winner.',
    tech: ['Python', 'IoT', 'SCADA'],
    href: 'https://github.com/agarwalvivek29/hackkarnataka',
    // projectPage: '/projects/sih-scada',
  },
  {
    title: 'Bounty Hub',
    description: 'On-chain bounty platform for open-source repos. Maintainers create ETH bounties from GitHub comments, contributors get paid automatically on merge via Base smart contract escrow.',
    tech: ['TypeScript', 'Solidity', 'Base', 'GitHub API', 'Next.js'],
    href: 'https://bounty-hub.agarwalvivek.com',
    // projectPage: '/projects/bounty-hub',
  },
  {
    title: 'Socket Chat',
    description: 'Real-time chat application with personal and channel-based messaging.',
    tech: ['React.js', 'Node.js', 'Socket.io', 'MongoDB'],
    href: 'https://github.com/agarwalvivek29/socket-chat',
    // projectPage: '/projects/socket-chat',
  },
  {
    title: 'Compute Village',
    description: 'Distributed compute project.',
    tech: ['TypeScript'],
    href: 'https://github.com/agarwalvivek29/compute_village',
    // projectPage: '/projects/compute-village',
  },
];
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto fade-in">
  <h2 class="text-2xl sm:text-3xl font-bold mb-10">Projects</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {projects.map((project) => (
      <ProjectCard {...project} />
    ))}
  </div>
</section>
