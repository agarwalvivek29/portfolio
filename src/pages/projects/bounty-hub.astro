---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProjectPage from '../../components/ProjectPage.astro';
---

<Layout title="Bounty Hub — Vivek Agarwal">
  <Navbar />
  <ProjectPage
    title="Bounty Hub"
    tagline="Incentivize open-source contributions with on-chain ETH bounties on Base"
    problem="Open-source maintainers have no simple way to fund and reward contributions — existing tools require external sign-ups, off-chain payments, and manual overhead."
    solution="BountyHub brings bounties directly into GitHub via a bot. Comment /bounty 0.5ETH on any issue to lock funds in a smart contract escrow. Comment /reward @username when done — the contributor gets paid on-chain instantly and the issue closes automatically."
    technical="GitHub App bot listens to issue comments and triggers on-chain transactions on Base (Ethereum L2). Smart contracts handle escrow, locking funds on bounty creation and releasing them on reward. Maintainers deposit once and create multiple bounties from their balance. Every transaction is on-chain and transparent."
    tech={['TypeScript', 'Solidity', 'Base', 'GitHub API', 'Next.js']}
    github="https://github.com/agarwalvivek29/bounty-hub"
    deployment="https://bounty-hub.agarwalvivek.com"
  />
  <Footer />
</Layout>
